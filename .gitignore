# typedoc-plugin-markdown mirrors the input path `packages/*/dist/index.d.ts`
# in its output (`docs/api/<pkg>/dist/...`), so the broad `dist` rule above
# would silently drop the generated API tree. Un-ignore it explicitly.
!docs/api/**/dist
!docs/api/**/dist/**
.DS_Store
.claude
.pnpm-store
.turbo
**/.vitepress/cache
**/.vitepress/dist
*.log
packages/*/src/*.d.ts
packages/*/src/*.d.ts.map
packages/*/src/*.js
packages/*/src/*.js.map
packages/*/vitest.config.d.ts
packages/*/vitest.config.d.ts.map
packages/*/vitest.config.js
packages/*/vitest.config.js.map

# Build artifacts emitted by scripts/compile-data.mjs
packages/*/src/*.generated.ts
packages/*/data/devices.json
packages/*/data/media.json
