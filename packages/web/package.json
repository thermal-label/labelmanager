{
  "name": "@thermal-label/labelmanager-web",
  "version": "0.0.1",
  "description": "WebUSB browser driver for DYMO LabelManager printers",
  "type": "module",
  "author": "Mannes Brak",
  "license": "MIT",
  "homepage": "https://thermal-label.github.io/labelmanager/",
  "keywords": [
    "dymo",
    "labelmanager",
    "label-printer",
    "thermal-label",
    "webusb",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thermal-label/labelmanager.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/thermal-label/labelmanager/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mannes"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mannes"
    }
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@thermal-label/contracts": "^0.1.0",
    "@thermal-label/labelmanager-core": "workspace:*",
    "@thermal-label/transport": "^0.1.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "devDependencies": {
    "@mbtech-nl/tsconfig": "^1.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^26.1.0",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
}
