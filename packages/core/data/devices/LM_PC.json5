{
  key: 'LM_PC',
  name: 'LabelManager PC',
  family: 'labelmanager',
  transports: {
    usb: { vid: '0x0922', pid: '0x0011' },
  },
  engines: [
    {
      role: 'primary',
      protocol: 'd1-tape',
      dpi: 180,
      headDots: 64,
      mediaCompatibility: ['d1'],
    },
